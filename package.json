    "danger": "^11.3.1",
    "eslint": "^9.0.0",
    "postcss": "^8.5.16",
    "prettier": "^3.4.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.10",
    "tsx": "^4.20.6"
  },
  "dependencies": {
    "@next/third-parties": "^15.4.11",
